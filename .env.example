# Copy this file to `.env.local` in the project root and fill in your real values.
# Path:
# C:\Users\vrishn viswa\Documents\GitHub\Remote-Control\.env.local

# -------------------------------------------------------------------
# Clerk: required
# Get these from Clerk Dashboard -> API Keys
# Docs:
# https://clerk.com/docs/guides/development/clerk-environment-variables
# -------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# -------------------------------------------------------------------
# Clerk: recommended redirect config
# These make Clerk send users back to your app routes instead of defaults.
# -------------------------------------------------------------------
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Optional stricter redirects if you want to always force dashboard:
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# -------------------------------------------------------------------
# Convex: required
# NEXT_PUBLIC_CONVEX_URL is created/filled when you run `npx convex dev`
# or can be copied from Convex Dashboard -> Deployment Settings -> URL
# Docs:
# https://docs.convex.dev/quickstart/nextjs
# https://docs.convex.dev/client/react/deployment-urls
# -------------------------------------------------------------------
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# -------------------------------------------------------------------
# Convex HTTP Actions URL: required for the desktop connector pairing flow
# Copy the `.convex.site` URL from:
# Convex Dashboard -> Deployment Settings -> URL and Deploy Key
# Docs:
# https://docs.convex.dev/functions/http-actions
# -------------------------------------------------------------------
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# -------------------------------------------------------------------
# Convex auth backend: required
# This must be your Clerk Frontend API URL / issuer domain.
# Get it from Clerk Dashboard -> API Keys -> Frontend API URL
# Example dev format:
# https://verb-noun-00.clerk.accounts.dev
# Convex Clerk docs:
# https://docs.convex.dev/auth/clerk
# -------------------------------------------------------------------
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-frontend-api-url.clerk.accounts.dev
